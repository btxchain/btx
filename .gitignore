# Build subdirectories.
/*build*
!/build-aux
!/build_msvc

*.pyc

# Only ignore unexpected patches
*.patch
!contrib/guix/patches/*.patch
!depends/patches/**/*.patch

/CMakeUserPresets.json

# Previous releases
/releases

#build tests
test/lint/test_runner/target/

# Benchmark binaries
test/benchmark/matmul_bench

/guix-build-*

/ci/scratch/

# BTX local orchestration/test runtime artifacts
/.btx-parallel-test-logs/
/.btx-production-readiness/
/.btx-validation/
/.btx-metal/
/.codex-swarm/
/.ci-fuzz-corpus/
/.ci-fuzz-corpus-local/
/.ci-remote-logs/
/.ci-local/
/.ci-logs/
/.ci-failed-logs/
/.local-mac-matrix/
/.ci-lint-venv*/
/test/cache/
/test/config.ini

# Local CI live-capture artifacts (scripts/ci tooling)
/.ci-live-*/
/.ci-live-*.zip
/.ci-live-*.json
/.ci-jobs-*.json

# Lint caches
/.ruff_cache/

# Local GitHub Actions runner folders/secrets (never commit)
/.actions-runner*/
github.key

# Editor/IDE artifacts
/.idea/
/.vscode/
.DS_Store
*.swp
*~
.cache/*
btx-release-key/

# --- Local mining ops (added 2026-07-02): keys, state, logs, and big artifacts never commit ---
/Wallet/
/wallet-backup-*/
*.log
/btx-solo-stats.state.json
/_dbg_out.txt
/_dbg_err.txt
/btx-*.tar.gz
/snapshot.dat
/snapshot.latest.manifest.json
/bin/
/btx-mining-mode.conf
/btx-gui-actions.log
/.claude/
/my-wallet-backup/
/temp/
/v032.11-solver*/
/btx-gui-mode.txt
/btx-racer.mode
