if(POLICY CMP0009)
  cmake_policy(SET CMP0009 NEW)
endif()
if(POLICY CMP0057)
  cmake_policy(SET CMP0057 NEW)
endif()

set(COVERAGE_SOURCE_ROOT "@PROJECT_SOURCE_DIR@/src")
set(COVERAGE_BUILD_ROOT "@PROJECT_BINARY_DIR@")
set(COVERAGE_SCRIPT_ROOT "${CMAKE_CURRENT_LIST_DIR}")

file(GLOB_RECURSE coverage_build_dirs LIST_DIRECTORIES true "${COVERAGE_SCRIPT_ROOT}/src/*")
set(coverage_mirror_roots "${COVERAGE_SCRIPT_ROOT}/src")
foreach(coverage_dir IN LISTS coverage_build_dirs)
  if(IS_DIRECTORY "${coverage_dir}" AND "${coverage_dir}" MATCHES [[/CMakeFiles$]])
    get_filename_component(coverage_root "${coverage_dir}" DIRECTORY)
    list(APPEND coverage_mirror_roots "${coverage_root}")
  endif()
endforeach()
list(REMOVE_DUPLICATES coverage_mirror_roots)

foreach(coverage_root IN LISTS coverage_mirror_roots)
  file(RELATIVE_PATH coverage_relative_root "${COVERAGE_SCRIPT_ROOT}/src" "${coverage_root}")
  if(coverage_relative_root STREQUAL "")
    set(coverage_source_dir "${COVERAGE_SOURCE_ROOT}")
  else()
    set(coverage_source_dir "${COVERAGE_SOURCE_ROOT}/${coverage_relative_root}")
  endif()
  if(NOT IS_DIRECTORY "${coverage_source_dir}")
    continue()
  endif()

  file(GLOB coverage_source_entries LIST_DIRECTORIES true "${coverage_source_dir}/*")
  set(coverage_source_names)
  foreach(coverage_entry IN LISTS coverage_source_entries)
    get_filename_component(coverage_name "${coverage_entry}" NAME)
    if(coverage_name STREQUAL "CMakeFiles")
      continue()
    endif()
    list(APPEND coverage_source_names "${coverage_name}")
  endforeach()

  file(GLOB coverage_existing_entries LIST_DIRECTORIES true "${coverage_root}/*")
  foreach(coverage_existing_entry IN LISTS coverage_existing_entries)
    get_filename_component(coverage_existing_name "${coverage_existing_entry}" NAME)
    if(coverage_existing_name STREQUAL "CMakeFiles")
      continue()
    endif()
    if(IS_SYMLINK "${coverage_existing_entry}" AND NOT coverage_existing_name IN_LIST coverage_source_names)
      file(REMOVE "${coverage_existing_entry}")
    endif()
  endforeach()

  foreach(coverage_entry IN LISTS coverage_source_entries)
    get_filename_component(coverage_name "${coverage_entry}" NAME)
    if(coverage_name STREQUAL "CMakeFiles")
      continue()
    endif()
    set(coverage_destination "${coverage_root}/${coverage_name}")
    if(IS_SYMLINK "${coverage_destination}")
      file(READ_SYMLINK "${coverage_destination}" coverage_target)
      if(IS_ABSOLUTE "${coverage_target}")
        set(coverage_target_path "${coverage_target}")
      else()
        set(coverage_target_path "${coverage_root}/${coverage_target}")
      endif()
      get_filename_component(coverage_target_real "${coverage_target_path}" REALPATH)
      get_filename_component(coverage_entry_real "${coverage_entry}" REALPATH)
      if(NOT coverage_target_real STREQUAL coverage_entry_real)
        file(REMOVE "${coverage_destination}")
      else()
        continue()
      endif()
    elseif(EXISTS "${coverage_destination}")
      continue()
    endif()

    execute_process(
      COMMAND ${CMAKE_COMMAND} -E create_symlink "${coverage_entry}" "${coverage_destination}"
      COMMAND_ERROR_IS_FATAL ANY
    )
  endforeach()
endforeach()
