# Multi-arch unit-test image for MatMul / consensus correctness (Ubuntu 24.04).
#
# This is the canonical multi-arch path (amd64 native + arm64/riscv64 under
# QEMU via buildx). Alpine was abandoned: stricter constexpr + QEMU ICE under
# high -j. Prefer this file over ad-hoc Dockerfiles under /tmp.
#
# --- Build (host) ---
#   # amd64 (native):
#   docker buildx build --platform linux/amd64 \
#     -f contrib/docker/Dockerfile.tests -t btx-test:amd64 --load .
#
#   # arm64 / riscv64 (QEMU user emulation; slow — use JOBS<=8):
#   docker buildx build --platform linux/arm64 \
#     --build-arg JOBS=8 \
#     -f contrib/docker/Dockerfile.tests -t btx-test:arm64 --load .
#   docker buildx build --platform linux/riscv64 \
#     --build-arg JOBS=8 \
#     -f contrib/docker/Dockerfile.tests -t btx-test:riscv64 --load .
#
# --- Run matmul* ---
#   docker run --rm btx-test:amd64 --run_test='matmul*'
#   docker run --rm --platform linux/arm64 btx-test:arm64 --run_test='matmul*'
#   docker run --rm --platform linux/riscv64 btx-test:riscv64 --run_test='matmul*'
#
# GPU golden certification is NOT done in this image (CPU-only). On silicon,
# set BTX_REQUIRE_GPU_GOLDEN=1 when running matmul_v4_backend_determinism_tests
# / matmul_v4_determinism_vectors (see doc/matmul-v4-gpu-backends.md).
#
# Status of in-flight QEMU lanes: doc/btx-matmul-v4.4-multiarch-qemu-status.md

FROM ubuntu:24.04 AS builder
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake pkg-config python3 ca-certificates \
    libboost-dev libboost-system-dev libboost-filesystem-dev \
    libboost-program-options-dev libboost-thread-dev libboost-chrono-dev \
    libboost-test-dev libevent-dev libsqlite3-dev libssl-dev \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /opt/btx
COPY . .
WORKDIR /opt/btx/build
ARG JOBS=8
RUN cmake .. \
    -DCMAKE_BUILD_TYPE=RelWithDebInfo \
    -DBUILD_DAEMON=ON -DBUILD_CLI=ON -DENABLE_WALLET=ON -DWITH_SQLITE=ON \
    -DBUILD_TESTS=ON -DBUILD_GUI=OFF -DBUILD_TX=OFF -DBUILD_UTIL=OFF \
    -DBUILD_WALLET_TOOL=OFF -DBUILD_BENCH=OFF -DBUILD_FUZZ_BINARY=OFF \
    -DBUILD_UTIL_CHAINSTATE=OFF -DWITH_BDB=OFF -DWITH_USDT=OFF \
    -DINSTALL_MAN=OFF -DWITH_CCACHE=OFF -DWITH_ZMQ=OFF \
 && cmake --build . --target test_btx -j"${JOBS}"

FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    libboost-system1.83.0 libboost-filesystem1.83.0 libboost-program-options1.83.0 \
    libboost-thread1.83.0 libboost-chrono1.83.0 libboost-test1.83.0 \
    libevent-2.1-7t64 libevent-core-2.1-7t64 libevent-extra-2.1-7t64 \
    libevent-pthreads-2.1-7t64 libsqlite3-0 libssl3t64 libstdc++6 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /opt/btx/build/bin/test_btx /usr/local/bin/test_btx
ENTRYPOINT ["/usr/local/bin/test_btx"]
