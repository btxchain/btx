    "what_would_constitute_a_reduction_relevant_finding": [
      {
        "id": "high_r2_surrogate",
        "signal": "High R\u00b2",
        "detail": "An affine or low-degree (deg \u2264 2 primary; deg \u2264 3 checklist) entrywise polynomial surrogate f(B32) matching Extract on \u2265 N=10^6 realistic B32 samples with R\u00b2 \u2273 0.05 (in-tree witness bar) \u2014 and especially R\u00b2 near 1 \u2014 that admits a Freivalds-usable rewrite through G,W,H. Toy harness R\u00b2 \u226b smoke thresholds is a reportable finding; firm FAIL needs the rewrite + cost vs HonestMAC.",
        "maps_to": "\u00a70.1 FAIL (affine/low-degree surrogate class); C15-A"
      },
      {
        "id": "zero_freivalds_residual",
        "signal": "Zero Freivalds residual",
        "detail": "A systematic zero (or Freivalds-soundness-bounded) residual r\u1d40(B\u0302\u2212B\u0302')s on dense samples for a cheap surrogate B\u0302' \u2014 i.e. the surrogate equals Extract on the probe with Adv \u2265 \u03b5 \u2014 while exact-int MAC cost stays \u2264 (1\u2212\u03b4)\u00b7HonestMAC(n). A single lucky zero on tiny toy-n is noise; systematic zeros with accepting sketches are FAIL.",
        "maps_to": "\u00a70.1 FAIL (Adv \u2265 \u03b5 at half-cost); C15-B"
      },
      {
        "id": "truncated_salt_equivalence_class",
        "signal": "Truncated salt equivalence class",
        "detail": "Any truncation / tiling / low-bit collapse of position salts (i,j) that creates a large equivalence class of cells sharing the same ChaCha Nonce96 high half (or otherwise reusable keystream), reopening a ~n/w \u2248 32\u00d7 thin-panel / shared-\u03c6 shortcut. Normative encoding REQUIRES full-width 32-bit i and j in nonce_second; a finding that consensus twins truncate, or that an adversary forces an effective truncation class with Adv \u2265 \u03b5 at \u2264 (1\u2212\u03b4)\u00b7HonestMAC, is FAIL.",
        "maps_to": "\u00a70.1 FAIL; \u00a70.2 attack-surface #6; matexpand_position_salt_differential"
      },
      {
        "id": "related_nonce_amortization",
        "signal": "Related-nonce GEMM amortization",
        "detail": "Mant/Scale lane-XOR identity (\u0394=MANT\u2295SCLE) is documented leftover ExtractStruct. FAIL only if an adversary amortizes beyond per-cell ChaCha with Adv\u2265\u03b5 at \u2264(1\u2212\u03b4)\u00b7HonestMAC \u2014 e.g. denser-than-chance B32 \u0394-mate graph enabling sub-GEMM solve. Firm pack \u226532 identity tuples + B32 \u0394-collision negative control are witnesses, not closure.",
        "maps_to": "\u00a70.2 #5; checklist A7; C15-C residue"
      }
    ],
    "non_findings": [
