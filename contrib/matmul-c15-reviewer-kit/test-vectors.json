    "what_would_constitute_a_reduction_relevant_finding": [
      {
        "id": "high_r2_surrogate",
        "signal": "High R\u00b2",
        "detail": "An affine or low-degree (deg \u2264 2 primary; deg \u2264 3 checklist) surrogate matching Extract on \u2265 N=10^6 realistic real-tile B32 samples with R\u00b2 \u2273 0.05 \u2014 and especially R\u00b2 near 1 \u2014 that admits a Freivalds-usable rewrite through G,W,H. The raw-only toy fit is an entrywise-marginal baseline; normative rejection alignment depends on all real values in the 32-cell tile, so firms must also test tile-local features. Firm FAIL needs the rewrite + cost vs HonestMAC.",
        "maps_to": "\u00a70.1 FAIL (affine/low-degree surrogate class); C15-A"
      },
      {
        "id": "zero_freivalds_residual",
        "signal": "Zero Freivalds residual",
        "detail": "A systematic zero (or Freivalds-soundness-bounded) residual r\u1d40(B\u0302\u2212B\u0302')s on dense samples for a cheap surrogate B\u0302' \u2014 i.e. the surrogate equals Extract on the probe with Adv \u2265 \u03b5 \u2014 while exact-int MAC cost stays \u2264 (1\u2212\u03b4)\u00b7HonestMAC(n). A single lucky zero on tiny toy-n is noise; systematic zeros with accepting sketches are FAIL.",
        "maps_to": "\u00a70.1 FAIL (Adv \u2265 \u03b5 at half-cost); C15-B"
      },
      {
        "id": "truncated_salt_equivalence_class",
        "signal": "Truncated salt equivalence class",
        "detail": "Any truncation / low-bit collapse of normative MX tile salts (i,bj), bj=j/32, that creates a large equivalence class sharing a ChaCha stream or scale. Normative encoding requires full-width 32-bit i and bj. At current production n=4096,w=1024, the raw panel ratio is n/w=4 (not the historical 32x); a consensus-twin truncation or effective reuse class still needs Adv \u2265 \u03b5 at \u2264 (1\u2212\u03b4)\u00b7HonestMAC to be FAIL.",
        "maps_to": "\u00a70.1 FAIL; \u00a70.2 attack-surface #6; matexpand_position_salt_differential"
      },
      {
        "id": "related_nonce_amortization",
        "signal": "Related-nonce GEMM amortization",
        "detail": "Mant/Scale lane-XOR identity (\u0394=MANT\u2295SCLE) belongs to the legacy per-cell ChaChaCell extractor and is retained only as a historical/differential witness. Normative Lever-B MX uses one MXBL stream and one hash-derived scale per real 32-value tile. The identity is therefore not a current consensus ExtractStruct attack without a new bridge to the MX construction.",
        "maps_to": "\u00a70.2 #5; checklist A7; C15-C residue"
      }
    ],
    "non_findings": [
      "Green goldens / AccelReplica parity alone",
      "IdealExtract 23-value alphabet or P(v=0)\u22481/11 (by design)",
      "Low toy R\u00b2 without a Freivalds-usable rewrite",
      "ChaCha20 looking like a PRF in isolation (does not imply MatExpand work lower bound)",
      "Legacy ChaChaCell MantPRF(raw)=ScalePRF(raw\u2295\u0394) identity alone (not normative MX)",
      "\u03bc\u2032\u2194e lock on first-nibble accept without MAC savings",
      "Zero/near-zero B32 \u0394-collisions on small grids (expected under uniform 32-bit XOR)"
    ]
  },
