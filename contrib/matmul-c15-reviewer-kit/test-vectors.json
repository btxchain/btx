  "endian_notes": {
    "seed_w_hex": "Bitcoin GetHex/FromHex display order (MSB digits first). Memory bytes = reverse(bytes.fromhex(hex)).",
    "prf_key_bytes": "SHA256 digest written in natural byte order; used as ChaCha20 key via eight LE32 words (RFC8439 / crypto/chacha20.h).",
    "mx_chacha_nonce96": "Normative tile stream: nonce_first = uint32(bj) XOR MXBL; nonce_second = (uint64(i)<<32) | uint64(bj), where bj=j/32. Seek(Nonce96{nonce_first, nonce_second}, remix) with remix as block counter. All 32 real B32 values affect rejection alignment.",
    "legacy_cell_chacha_nonce96": "Differential-only ChaChaCell path: nonce_first = uint32(raw) XOR MANT/SCLE; nonce_second = (uint64(i)<<32) | uint64(j). Not used by consensus MatExpand after Lever-B MX.",
    "legacy_keystream_le64": "Legacy ChaChaCell differential only: first 8 keystream bytes interpreted as little-endian uint64.",
    "mx_scale": "Normative e = SHA256(MXSCALE tag || prf_key || LE32(i) || LE32(bj))[0] & 3; return exact_mul(mu, 1<<e) \u2014 never signed left-shift of a negative mantissa."
  },
