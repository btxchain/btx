  "reduction_relevant_finding_notes": {
    "purpose": "Oracle hints for external reviewers \u2014 what would constitute a reduction-relevant / \u00a70.1 FAIL finding. Not a theorem; C-15 remains OPEN.",
    "packet_refs": [
      "doc/btx-matmul-v4.4-lt-external-c15-packet.md \u00a70.1 (FAIL criteria)",
      "doc/btx-matmul-v4.4-lt-external-c15-packet.md \u00a70.2 (BTX-C15-NonCollapse-v1)",
