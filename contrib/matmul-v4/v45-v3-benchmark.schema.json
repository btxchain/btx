{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BTX v4.5 V3 production campaign sample",
  "type": "object",
  "required": ["git_commit", "backend", "config_version", "packed_bytes", "expanded_bytes", "device_event_ns", "nonce_per_s", "peak_ready", "exact_match"],
  "properties": {
    "git_commit": { "type": "string" },
    "dirty": { "type": "boolean" },
    "binary_sha256": { "type": "string" },
    "cuda_version": { "type": "string" },
    "driver_version": { "type": "string" },
    "gpu_name": { "type": "string" },
    "gpu_uuid": { "type": "string" },
    "backend": { "type": "string" },
    "native_instruction_evidence": { "type": "string" },
    "config_version": { "type": "integer" },
    "bank_pages": { "type": "integer" },
    "rows_per_lobe": { "type": "integer" },
    "pages_per_barrier_lobe": { "type": "integer" },
    "packed_bytes": { "type": "integer" },
    "expanded_bytes": { "type": "integer" },
    "residency_mode": { "type": "string" },
    "q_batch": { "type": "integer" },
    "device_event_ns": { "type": "integer" },
    "host_wall_ns": { "type": "integer" },
    "nonce_per_s": { "type": "number" },
    "joules_per_nonce": { "type": "number" },
    "exact_match": { "type": "boolean" },
    "peak_ready": { "type": "boolean" },
    "peak_ready_deficit": { "type": "string" },
    "rental_usd_per_hour": { "type": "number" },
    "rental_price_source": { "type": "string" },
    "rental_price_timestamp": { "type": "string" }
  }
}
